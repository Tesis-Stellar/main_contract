# ============================================================================
# Stellar Tickets On-Chain - Variables de Entorno (Testnet/Futurenet)
# ============================================================================
# Copiar a .env.local y completar valores reales.

# Red
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Identidades/aliases operativos
ADMIN_FABRICA_ALIAS=admin_fabrica
ORGANIZADOR_ALIAS=organizador_evento
PLATAFORMA_ALIAS=wallet_plataforma
VERIFICADOR_ALIAS=verificador

# Dirección de cuentas (opcional para scripts de validación)
ADMIN_FABRICA_ADDRESS=
ORGANIZADOR_EVENTO_ADDRESS=
WALLET_PLATAFORMA_ADDRESS=
VERIFICADOR_ADDRESS=

# Artefactos de despliegue
FACTORY_WASM_PATH=target/wasm32v1-none/release/factory_contract.wasm
EVENT_WASM_PATH=target/wasm32v1-none/release/event_contract.wasm
EVENT_WASM_HASH=

# Contratos desplegados (se llenan post-deploy)
FACTORY_CONTRACT_ID=
EVENT_CONTRACT_ID=

# Configuración de evento por defecto (sin hardcode en scripts)
EVENT_ID=
COMISION_ORGANIZADOR_BP=
COMISION_PLATAFORMA_BP=
CAPACIDAD_TOTAL=
TOKEN_PAGO_ADDRESS=
WALLET_ORGANIZADOR_ADDRESS=
WALLET_PLATAFORMA_EVENTO_ADDRESS=

# Salt de despliegue (si aplica en factory deployer)
EVENT_DEPLOY_SALT=

# Opcional: archivo de reporte de despliegue
DEPLOYMENT_REPORT_PATH=deployment_report_testnet.md
